3. Enhanced Executive Dashboard

```dart
// lib/screens/dashboard/executive_dashboard.dart
import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import 'package:sena_farmerp/core/app_theme.dart';
import 'package:sena_farmerp/widgets/common/custom_app_bar.dart';
import 'package:sena_farmerp/widgets/common/dashboard_cards.dart';
import 'package:sena_farmerp/widgets/charts/production_chart.dart';
import 'package:sena_farmerp/widgets/charts/financial_chart.dart';
import 'package:sena_farmerp/widgets/charts/impact_chart.dart';
import 'package:sena_farmerp/widgets/charts/weather_chart.dart';
import 'package:sena_farmerp/services/analytics_service.dart';
import 'package:sena_farmerp/services/weather_service.dart';

class ExecutiveDashboard extends StatefulWidget {
  @override
  _ExecutiveDashboardState createState() => _ExecutiveDashboardState();
}

class _ExecutiveDashboardState extends State<ExecutiveDashboard> 
    with SingleTickerProviderStateMixin, AutomaticKeepAliveClientMixin {
  
  late TabController _tabController;
  final GlobalKey<RefreshIndicatorState> _refreshIndicatorKey = 
      GlobalKey<RefreshIndicatorState>();

  @override
  void initState() {
    super.initState();
    _tabController = TabController(length: 6, vsync: this);
    _loadDashboardData();
  }

  Future<void> _loadDashboardData() async {
    await Future.wait([
      Provider.of<AnalyticsService>(context, listen: false).loadGlobalAnalytics(),
      Provider.of<WeatherService>(context, listen: false).loadRegionalWeather(),
    ]);
  }

  @override
  Widget build(BuildContext context) {
    super.build(context);
    return Scaffold(
      backgroundColor: AppTheme.backgroundWhite,
      appBar: CustomAppBar(
        title: 'Sena FarmERP v6.0',
        subtitle: 'Global Agricultural Command Center',
        actions: [
          _buildRegionSelector(),
          _buildNotificationButton(),
          _buildProfileMenu(),
        ],
      ),
      body: RefreshIndicator(
        key: _refreshIndicatorKey,
        onRefresh: _loadDashboardData,
        child: Column(
          children: [
            // Global Quick Stats
            _buildGlobalQuickStats(),
            
            // Enhanced Tab Navigation
            _buildEnhancedTabBar(),
            
            // Tab Content
            Expanded(
              child: TabBarView(
                controller: _tabController,
                children: [
                  _buildOperationalIntelligence(),
                  _buildProductionOverview(),
                  _buildFinancialEcosystem(),
                  _buildValueChainOrchestration(),
                  _buildClimateSmartAnalytics(),
                  _buildImpactDashboard(),
                ],
              ),
            ),
          ],
        ),
      ),
      floatingActionButton: FloatingActionButton(
        onPressed: _showGlobalAIAdvisor,
        backgroundColor: AppTheme.primaryOrange,
        child: Icon(Icons.psychology, color: Colors.white),
        tooltip: 'Global AI Agricultural Advisor',
      ),
    );
  }

  Widget _buildGlobalQuickStats() {
    return Consumer<AnalyticsService>(
      builder: (context, analytics, child) {
        return Container(
          padding: EdgeInsets.all(20),
          decoration: BoxDecoration(
            gradient: LinearGradient(
              begin: Alignment.topLeft,
              end: Alignment.bottomRight,
              colors: [AppTheme.primaryGreen, AppTheme.darkGreen],
            ),
            borderRadius: BorderRadius.only(
              bottomLeft: Radius.circular(24),
              bottomRight: Radius.circular(24),
            ),
          ),
          child: Column(
            children: [
              Row(
                mainAxisAlignment: MainAxisAlignment.spaceAround,
                children: [
                  _QuickStatItem(
                    value: analytics.totalFarmers.toString(),
                    label: 'Farmers Registered',
                    icon: Icons.people,
                    trend: 12.3,
                  ),
                  _QuickStatItem(
                    value: analytics.totalCommodities.toString(),
                    label: 'Commodities',
                    icon: Icons.agriculture,
                    trend: 8.7,
                  ),
                  _QuickStatItem(
                    value: '\$${analytics.monthlyVolume}M',
                    label: 'Monthly Volume',
                    icon: Icons.attach_money,
                    trend: 15.2,
                  ),
                  _QuickStatItem(
                    value: '${analytics.climateSmartPercentage}%',
                    label: 'Climate Smart',
                    icon: Icons.eco,
                    trend: 22.5,
                  ),
                ],
              ),
              SizedBox(height: 12),
              // Real-time alerts strip
              _buildRealTimeAlertsStrip(),
            ],
          ),
        );
      },
    );
  }

  Widget _buildEnhancedTabBar() {
    return Container(
      decoration: BoxDecoration(
        color: Colors.white,
        boxShadow: [
          BoxShadow(
            color: Colors.black12,
            blurRadius: 8,
            offset: Offset(0, 2),
          ),
        ],
      ),
      child: TabBar(
        controller: _tabController,
        labelColor: AppTheme.primaryGreen,
        unselectedLabelColor: Colors.grey,
        indicatorColor: AppTheme.primaryGreen,
        indicatorWeight: 3,
        indicatorSize: TabBarIndicatorSize.label,
        isScrollable: true,
        tabs: [
          Tab(icon: Icon(Icons.dashboard), text: 'Operations'),
          Tab(icon: Icon(Icons.analytics), text: 'Production'),
          Tab(icon: Icon(Icons.account_balance), text: 'Financial'),
          Tab(icon: Icon(Icons.link), text: 'Value Chain'),
          Tab(icon: Icon(Icons.wb_sunny), text: 'Climate'),
          Tab(icon: Icon(Icons.assessment), text: 'Impact'),
        ],
      ),
    );
  }

  Widget _buildOperationalIntelligence() {
    return SingleChildScrollView(
      padding: EdgeInsets.all(16),
      child: Column(
        children: [
          // Real-time Alerts Grid
          DashboardCard(
            title: 'Real-Time Operational Alerts',
            child: GridView.count(
              shrinkWrap: true,
              physics: NeverScrollableScrollPhysics(),
              crossAxisCount: 2,
              crossAxisSpacing: 12,
              mainAxisSpacing: 12,
              children: [
                _AlertCard(
                  type: AlertType.weather,
                  title: 'Weather Alert',
                  message: 'Heavy rainfall expected in 48 hours',
                  severity: AlertSeverity.high,
                  region: 'Bale Zone',
                ),
                _AlertCard(
                  type: AlertType.disease,
                  title: 'Disease Risk',
                  message: 'Coffee berry disease risk detected',
                  severity: AlertSeverity.medium,
                  region: 'Sidama Zone',
                ),
                _AlertCard(
                  type: AlertType.market,
                  title: 'Market Opportunity',
                  message: 'Price surge in coffee exports',
                  severity: AlertSeverity.low,
                  region: 'Global',
                ),
                _AlertCard(
                  type: AlertType.logistics,
                  title: 'Logistics Update',
                  message: 'Transport optimization available',
                  severity: AlertSeverity.medium,
                  region: 'Eastern Region',
                ),
              ],
            ),
          ),
          SizedBox(height: 16),
          
          // Regional Performance
          DashboardCard(
            title: 'Regional Performance Metrics',
            child: Consumer<AnalyticsService>(
              builder: (context, analytics, child) {
                return Column(
                  children: analytics.regionalPerformance.map((region) => 
                    _RegionPerformanceTile(region: region)
                  ).toList(),
                );
              },
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildProductionOverview() {
    return SingleChildScrollView(
      padding: EdgeInsets.all(16),
      child: Column(
        children: [
          DashboardCard(
            title: 'Multi-Commodity Production Analytics',
            child: ProductionChart(),
          ),
          SizedBox(height: 16),
          Row(
            children: [
              Expanded(
                child: DashboardCard(
                  title: 'Top Performing Commodities',
                  child: _TopCommoditiesList(),
                ),
              ),
              Expanded(
                child: DashboardCard(
                  title: 'Growth Limiting Factors',
                  child: _GrowthFactorsAnalysis(),
                ),
              ),
            ],
          ),
        ],
      ),
    );
  }

  Widget _buildRealTimeAlertsStrip() {
    return Container(
      padding: EdgeInsets.symmetric(horizontal: 16, vertical: 8),
      decoration: BoxDecoration(
        color: Colors.orange[50],
        borderRadius: BorderRadius.circular(8),
        border: Border.all(color: Colors.orange[200]!),
      ),
      child: Row(
        children: [
          Icon(Icons.warning, color: Colors.orange, size: 16),
          SizedBox(width: 8),
          Expanded(
            child: Text(
              '3 active alerts in your regions',
              style: TextStyle(color: Colors.orange[800], fontSize: 12),
            ),
          ),
          GestureDetector(
            onTap: _viewAllAlerts,
            child: Text(
              'View All',
              style: TextStyle(
                color: AppTheme.primaryGreen,
                fontSize: 12,
                fontWeight: FontWeight.bold,
              ),
            ),
          ),
        ],
      ),
    );
  }

  // Additional builder methods for other tabs...
  Widget _buildFinancialEcosystem() => _buildFinancialTab();
  Widget _buildValueChainOrchestration() => _buildValueChainTab();
  Widget _buildClimateSmartAnalytics() => _buildClimateTab();
  Widget _buildImpactDashboard() => _buildImpactTab();

  Widget _buildRegionSelector() {
    return PopupMenuButton<String>(
      icon: Icon(Icons.location_on, color: Colors.white),
      itemBuilder: (context) => [
        PopupMenuItem(value: 'global', child: Text('🌍 Global View')),
        PopupMenuItem(value: 'ethiopia', child: Text('🇪🇹 Ethiopia')),
        PopupMenuItem(value: 'kenya', child: Text('🇰🇪 Kenya')),
        PopupMenuItem(value: 'rwanda', child: Text('🇷🇼 Rwanda')),
        PopupMenuItem(value: 'tanzania', child: Text('🇹🇿 Tanzania')),
      ],
      onSelected: (region) {
        _changeRegion(region);
      },
    );
  }

  Widget _buildNotificationButton() {
    return IconButton(
      icon: Stack(
        children: [
          Icon(Icons.notifications, color: Colors.white),
          Positioned(
            right: 0,
            child: Container(
              padding: EdgeInsets.all(2),
              decoration: BoxDecoration(
                color: Colors.red,
                borderRadius: BorderRadius.circular(6),
              ),
              constraints: BoxConstraints(
                minWidth: 14,
                minHeight: 14,
              ),
              child: Text(
                '3',
                style: TextStyle(
                  color: Colors.white,
                  fontSize: 8,
                  fontWeight: FontWeight.bold,
                ),
                textAlign: TextAlign.center,
              ),
            ),
          )
        ],
      ),
      onPressed: _showNotifications,
    );
  }

  Widget _buildProfileMenu() {
    return PopupMenuButton<String>(
      icon: CircleAvatar(
        backgroundColor: AppTheme.primaryOrange,
        child: Icon(Icons.person, color: Colors.white),
      ),
      itemBuilder: (context) => [
        PopupMenuItem(value: 'profile', child: Text('👤 Profile')),
        PopupMenuItem(value: 'settings', child: Text('⚙️ Settings')),
        PopupMenuItem(value: 'help', child: Text('❓ Help & Support')),
        PopupMenuItem(value: 'logout', child: Text('🚪 Logout')),
      ],
      onSelected: (value) => _handleProfileAction(value),
    );
  }

  void _showGlobalAIAdvisor() {
    showModalBottomSheet(
      context: context,
      isScrollControlled: true,
      backgroundColor: Colors.transparent,
      builder: (context) => Container(
        height: MediaQuery.of(context).size.height * 0.85,
        decoration: BoxDecoration(
          color: Colors.white,
          borderRadius: BorderRadius.only(
            topLeft: Radius.circular(24),
            topRight: Radius.circular(24),
          ),
        ),
        child: _GlobalAIAdvisorPanel(),
      ),
    );
  }

  void _changeRegion(String region) {
    // Implement region change logic
  }

  void _viewAllAlerts() {
    // Navigate to alerts screen
  }

  void _showNotifications() {
    // Navigate to notifications
