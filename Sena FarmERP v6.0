10. Enhanced API Service

```dart
// lib/services/api_service.dart
import 'dart:convert';
import 'package:http/http.dart' as http;
import 'package:provider/provider.dart';
import 'package:sena_farmerp/core/app_config.dart';
import 'package:sena_farmerp/models/farmer_model.dart';
import 'package:sena_farmerp/models/commodity_model.dart';
import 'package:sena_farmerp/models/value_chain_model.dart';

class ApiService with ChangeNotifier {
  static const int timeoutSeconds = 30;
  
  final String baseUrl = AppConfig.baseUrl;
  final Map<String, String> _headers = {
    'Content-Type': 'application/json',
    'Accept': 'application/json',
  };

  String? _authToken;
  bool _isInitialized = false;

  // Cache for performance
  final Map<String, dynamic> _cache = {};
  final Map<String, DateTime> _cacheTimestamps = {};

  Future<void> initialize() async {
    // Initialize authentication and other setup
    _isInitialized = true;
    notifyListeners();
  }

  // Enhanced Farmer Management
  Future<List<FarmerProfile>> getFarmers({int page = 1, int limit = 50}) async {
    final cacheKey = 'farmers_page_${page}_limit_$limit';
    
    if (_isCacheValid(cacheKey)) {
      return _cache[cacheKey] as List<FarmerProfile>;
    }

    try {
      final response = await http.get(
        Uri.parse('$baseUrl/farmers?page=$page&limit=$limit'),
        headers: _headers,
      ).timeout(Duration(seconds: timeoutSeconds));

      if (response.statusCode == 200) {
        final List<dynamic> data = json.decode(response.body);
        final farmers = data.map((json) => FarmerProfile.fromJson(json)).toList();
        
        _cache[cacheKey] = farmers;
        _cacheTimestamps[cacheKey] = DateTime.now();
        
        return farmers;
      } else {
        throw ApiException(
          'Failed to load farmers: ${response.statusCode}',
          response.statusCode,
        );
      }
    } catch (e) {
      // Fallback to mock data for demo
      return _getMockFarmers();
    }
  }

  Future<FarmerProfile> registerFarmer(FarmerProfile farmer) async {
    try {
      final response = await http.post(
        Uri.parse('$baseUrl/farmers'),
        headers: _headers,
        body: json.encode(farmer.toJson()),
      ).timeout(Duration(seconds: timeoutSeconds));

      if (response.statusCode == 201) {
        final dynamic data = json.decode(response.body);
        return FarmerProfile.fromJson(data);
      } else {
        throw ApiException(
          'Failed to register farmer: ${response.statusCode}',
          response.statusCode,
        );
      }
    } catch (e) {
      throw ApiException('Network error: $e', 0);
    }
  }

  // Enhanced Commodity Management
  Future<List<Commodity>> getCommodities() async {
    const cacheKey = 'commodities';
    
    if (_isCacheValid(cacheKey)) {
      return _cache[cacheKey] as List<Commodity>;
    }

    try {
      final response = await http.get(
        Uri.parse('$baseUrl/commodities'),
        headers: _headers,
      ).timeout(Duration(seconds: timeoutSeconds));

      if (response.statusCode == 200) {
        final List<dynamic> data = json.decode(response.body);
        final commodities = data.map((json) => Commodity.fromJson(json)).toList();
        
        _cache[cacheKey] = commodities;
        _cacheTimestamps[cacheKey] = DateTime.now();
        
        return commodities;
      } else {
        throw ApiException(
          'Failed to load commodities: ${response.statusCode}',
          response.statusCode,
        );
      }
    } catch (e) {
      // Fallback to mock data
      return _getMockCommodities();
    }
  }

  // Enhanced Value Chain Management
  Future<List<ValueChainPathway>> getValueChains() async {
    const cacheKey = 'value_chains';
    
    if (_isCacheValid(cacheKey)) {
      return _cache[cacheKey] as List<ValueChainPathway>;
    }

    try {
      final response = await http.get(
        Uri.parse('$baseUrl/value-chains'),
        headers: _headers,
      ).timeout(Duration(seconds: timeoutSeconds));

      if (response.statusCode == 200) {
        final List<dynamic> data = json.decode(response.body);
        final pathways = data.map((json) => ValueChainPathway.fromJson(json)).toList();
        
        _cache[cacheKey] = pathways;
        _cacheTimestamps[cacheKey] = DateTime.now();
        
        return pathways;
      } else {
        throw ApiException(
          'Failed to load value chains: ${response.statusCode}',
          response.statusCode,
        );
      }
    } catch (e) {
      // Fallback to mock data
      return _getMockValueChains();
    }
  }

  // Utility Methods
  bool _isCacheValid(String key) {
    if (!_cache.containsKey(key) || !_cacheTimestamps.containsKey(key)) {
      return false;
    }
    
    final timestamp = _cacheTimestamps[key]!;
    final now = DateTime.now();
    final difference = now.difference(timestamp);
    
    return difference.inMinutes < AppConfig.cacheDurationMinutes;
  }

  void clearCache() {
    _cache.clear();
    _cacheTimestamps.clear();
    notifyListeners();
  }

  // Mock data for demonstration
  List<FarmerProfile> _getMockFarmers() {
    return [
      FarmerProfile(
        id: 'FARMER-001',
        name: 'Abebe Kebede',
        phone: '+251911223344',
        email: 'abebe@example.com',
        dateOfBirth: DateTime(1980, 1, 1),
        gender: Gender.male,
        village: 'Bale Zone',
        district: 'Agarfa',
        region: 'Oromia',
        farmSize: 2.5,
        latitude: 6.7539,
        longitude: 39.6183,
        registrationDate: DateTime(2023, 1, 15),
        annualIncome: 25000,
        commodities: ['coffee', 'maize'],
        assets: [
          FarmAsset(
            id: 'ASSET-001',
            type: AssetType.land,
            description: 'Main farmland',
            value: 50000,
            acquisitionDate: DateTime(2010, 1, 1),
          ),
        ],
        financialProfile: FinancialProfile(
          creditScore: 720,
          savings: 15000,
          loans: 5000,
          insurancePolicies: [],
          recentTransactions: [],
        ),
        socialInclusion: SocialInclusionProfile(
          isWomenLed: false,
          isYouthLed: false,
          isDisabled: false,
          isMinority: false,
          certificates: [],
          supportPrograms: [],
        ),
        digitalLiteracy: DigitalLiteracy(
          canUseSmartphone: true,
          canUseApps: true,
          hasInternetAccess: true,
          preferredLanguage: 'am',
          usedApps: ['Telegram', 'Mobile Banking'],
        ),
        lastUpdated: DateTime.now(),
      ),
      // Add more mock farmers as needed
    ];
  }

  List<Commodity> _getMockCommodities() {
    return [
      Commodity(
        id: 'COFFEE-001',
        name: 'Arabica Coffee',
        variety: 'Typica',
        type: CommodityType.crop,
        plantedArea: 1.5,
        expectedYield: 800,
        currentYield: 750,
        healthScore: 85,
        growthProgress: 75,
        waterRequirement: 1200,
        soilType: 'Volcanic',
        climateZone: 'Highland',
        plantingDate: DateTime(2023, 3, 1),
        harvestDate: DateTime(2023, 11, 1),
        isActive: true,
        lastUpdated: DateTime.now(),
      ),
      // Add more mock commodities
    ];
  }

  List<ValueChainPathway> _getMockValueChains() {
    return [
      ValueChainPathway(
        id: 'VC-COFFEE-001',
        commodity: 'coffee',
        name: 'Premium Arabica Coffee Value Chain',
        description: 'End-to-end value chain for premium arabica coffee',
        stages: [
          ValueChainStage(
            name: 'Seed Multiplication & Nursery',
            description: 'Certified seed production and seedling preparation',
            actors: ['Seed SMEs', 'Nursery Operators'],
            digitalTools: ['Blockchain Certification', 'Quality Tracker'],
            efficiency: 92,
            quality: 95,
            timeliness: 88,
            costEffectiveness: 85,
          ),
          // Add more stages
        ],
        totalParticipants: 1500,
        estimatedValue: 2500000,
        efficiency: 89,
        sustainabilityScore: 87,
        lastUpdated: DateTime.now(),
      ),
    ];
  }
}

class ApiException implements Exception {
  final String message;
  final int statusCode;

  ApiException(this.message, this.statusCode);

  @override
  String toString() => 'ApiException: $message (Status: $statusCode)';
}
