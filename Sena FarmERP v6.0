  @override
  bool get wantKeepAlive => true;
}

class _QuickStatItem extends StatelessWidget {
  final String value;
  final String label;
  final IconData icon;
  final double trend;

  const _QuickStatItem({
    required this.value,
    required this.label,
    required this.icon,
    required this.trend,
  });

  @override
  Widget build(BuildContext context) {
    return Column(
      children: [
        Container(
          padding: EdgeInsets.all(12),
          decoration: BoxDecoration(
            color: Colors.white.withOpacity(0.2),
            borderRadius: BorderRadius.circular(12),
          ),
          child: Icon(icon, color: Colors.white, size: 24),
        ),
        SizedBox(height: 8),
        Text(
          value,
          style: TextStyle(
            color: Colors.white,
            fontSize: 18,
            fontWeight: FontWeight.bold,
          ),
        ),
        SizedBox(height: 4),
        Text(
          label,
          style: TextStyle(
            color: Colors.white70,
            fontSize: 12,
          ),
        ),
        SizedBox(height: 4),
        Row(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(
              trend >= 0 ? Icons.arrow_upward : Icons.arrow_downward,
              color: trend >= 0 ? Colors.green[200] : Colors.red[200],
              size: 12,
            ),
            SizedBox(width: 2),
            Text(
              '${trend.abs()}%',
              style: TextStyle(
                color: trend >= 0 ? Colors.green[200] : Colors.red[200],
                fontSize: 10,
              ),
            ),
          ],
        ),
      ],
    );
  }
}

class _AlertCard extends StatelessWidget {
  final AlertType type;
  final String title;
  final String message;
  final AlertSeverity severity;
  final String region;

  const _AlertCard({
    required this.type,
    required this.title,
    required this.message,
    required this.severity,
    required this.region,
  });

  @override
  Widget build(BuildContext context) {
    Color backgroundColor;
    Color textColor;
    
    switch (severity) {
      case AlertSeverity.high:
        backgroundColor = Colors.red[50]!;
        textColor = Colors.red[800]!;
        break;
      case AlertSeverity.medium:
        backgroundColor = Colors.orange[50]!;
        textColor = Colors.orange[800]!;
        break;
      case AlertSeverity.low:
        backgroundColor = Colors.blue[50]!;
        textColor = Colors.blue[800]!;
        break;
    }

    return Container(
      decoration: BoxDecoration(
        color: backgroundColor,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: textColor.withOpacity(0.3)),
      ),
      padding: EdgeInsets.all(12),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              Container(
                width: 8,
                height: 8,
                decoration: BoxDecoration(
                  color: textColor,
                  shape: BoxShape.circle,
                ),
              ),
              SizedBox(width: 8),
              Text(
                title,
                style: TextStyle(
                  color: textColor,
                  fontWeight: FontWeight.bold,
                  fontSize: 12,
                ),
              ),
            ],
          ),
          SizedBox(height: 8),
          Text(
            message,
            style: TextStyle(
              color: textColor,
              fontSize: 10,
            ),
            maxLines: 2,
            overflow: TextOverflow.ellipsis,
          ),
          SizedBox(height: 4),
          Text(
            region,
            style: TextStyle(
              color: textColor.withOpacity(0.7),
              fontSize: 9,
            ),
          ),
        ],
      ),
    );
  }
}

enum AlertType { weather, disease, market, logistics, financial }
enum AlertSeverity { high, medium, low }
```

4. Enhanced Farmer Management with Mass Registration

```dart
// lib/screens/farmer_management/farmer_registry.dart
import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import 'package:sena_farmerp/core/app_theme.dart';
import 'package:sena_farmerp/models/farmer_model.dart';
import 'package:sena_farmerp/services/api_service.dart';
import 'package:sena_farmerp/widgets/common/custom_app_bar.dart';
import 'package:sena_farmerp/widgets/common/dashboard_cards.dart';
import 'package:sena_farmerp/widgets/forms/farmer_registration_form.dart';

class FarmerRegistryScreen extends StatefulWidget {
  @override
  _FarmerRegistryScreenState createState() => _FarmerRegistryScreenState();
}

class _FarmerRegistryScreenState extends State<FarmerRegistryScreen> 
    with AutomaticKeepAliveClientMixin {
  
  final TextEditingController _searchController = TextEditingController();
  final ScrollController _scrollController = ScrollController();
  
  List<FarmerProfile> _farmers = [];
  List<FarmerProfile> _filteredFarmers = [];
  bool _isLoading = false;
  int _currentPage = 1;
  bool _hasMore = true;

  @override
  void initState() {
    super.initState();
    _loadFarmers();
    _searchController.addListener(_filterFarmers);
    _scrollController.addListener(_scrollListener);
  }

  Future<void> _loadFarmers({bool loadMore = false}) async {
    if (_isLoading) return;
    
    setState(() {
      _isLoading = true;
    });

    try {
      final newFarmers = await Provider.of<ApiService>(context, listen: false)
          .getFarmers(page: loadMore ? _currentPage + 1 : 1);
      
      setState(() {
        if (loadMore) {
          _farmers.addAll(newFarmers);
          _currentPage++;
        } else {
          _farmers = newFarmers;
          _currentPage = 1;
        }
        _filteredFarmers = _farmers;
        _hasMore = newFarmers.length == 20; // Assuming 20 per page
        _isLoading = false;
      });
    } catch (e) {
      setState(() {
        _isLoading = false;
      });
      _showErrorSnackbar('Failed to load farmers: $e');
    }
  }

  void _scrollListener() {
    if (_scrollController.offset >= 
        _scrollController.position.maxScrollExtent && 
        !_scrollController.position.outOfRange) {
      if (_hasMore && !_isLoading) {
        _loadFarmers(loadMore: true);
      }
    }
  }

  void _filterFarmers() {
    final query = _searchController.text.toLowerCase();
    setState(() {
      _filteredFarmers = _farmers.where((farmer) {
        return farmer.name.toLowerCase().contains(query) ||
            farmer.phone.contains(query) ||
            farmer.village.toLowerCase().contains(query) ||
            farmer.id.toLowerCase().contains(query);
      }).toList();
    });
  }

  @override
  Widget build(BuildContext context) {
    super.build(context);
    return Scaffold(
      appBar: CustomAppBar(
        title: 'Farmer Registry',
        subtitle: '${_farmers.length} Farmers Registered',
        actions: [
          IconButton(
            icon: Icon(Icons.add),
            onPressed: _showRegistrationForm,
            tooltip: 'Add New Farmer',
          ),
          IconButton(
            icon: Icon(Icons.cloud_download),
            onPressed: _exportData,
            tooltip: 'Export Data',
          ),
          IconButton(
            icon: Icon(Icons.filter_alt),
            onPressed: _showFilters,
            tooltip: 'Filter Farmers',
          ),
        ],
      ),
      body: Column(
        children: [
          // Enhanced Search and Filters
          _buildSearchAndFilters(),
          
          // Statistics Overview
          _buildStatisticsOverview(),
          
          // Farmers List
          Expanded(
            child: _buildFarmersList(),
          ),
        ],
      ),
      floatingActionButton: FloatingActionButton(
        onPressed: _showRegistrationForm,
        backgroundColor: AppTheme.primaryGreen,
        child: Icon(Icons.add, color: Colors.white),
        tooltip: 'Register New Farmer',
      ),
    );
  }

  Widget _buildSearchAndFilters() {
    return Padding(
      padding: EdgeInsets.all(16),
      child: Column(
        children: [
          TextField(
            controller: _searchController,
            decoration: InputDecoration(
              hintText: 'Search farmers by name, phone, village...',
              prefixIcon: Icon(Icons.search),
              suffixIcon: _searchController.text.isNotEmpty
                  ? IconButton(
                      icon: Icon(Icons.clear),
                      onPressed: () {
                        _searchController.clear();
                        _filterFarmers();
                      },
                    )
                  : null,
              border: OutlineInputBorder(
                borderRadius: BorderRadius.circular(12),
              ),
            ),
          ),
          SizedBox(height: 12),
          // Quick filter chips
          _buildQuickFilters(),
        ],
      ),
    );
  }

  Widget _buildQuickFilters() {
    return SingleChildScrollView(
      scrollDirection: Axis.horizontal,
      child: Row(
        children: [
          FilterChip(
            label: Text('All Farmers'),
            selected: true,
            onSelected: (_) {},
          ),
          SizedBox(width: 8),
          FilterChip(
            label: Text('Women Led'),
            onSelected: (_) {},
          ),
          SizedBox(width: 8),
          FilterChip(
            label: Text('Youth Led'),
            onSelected: (_) {},
          ),
          SizedBox(width: 8),
          FilterChip(
            label: Text('Needs Support'),
            onSelected: (_) {},
          ),
        ],
      ),
    );
  }

  Widget _buildStatisticsOverview() {
    return Container(
      padding: EdgeInsets.symmetric(horizontal: 16, vertical: 12),
      decoration: BoxDecoration(
        color: AppTheme.backgroundWhite,
        border: Border(bottom: BorderSide(color: Colors.grey[200]!)),
      ),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceAround,
        children: [
          _StatItem(
            value: _farmers.length.toString(),
            label: 'Total',
            icon: Icons.people,
            color: AppTheme.primaryGreen,
          ),
          _StatItem(
            value: '${_calculateWomenPercentage()}%',
            label: 'Women',
            icon: Icons.female,
            color: Colors.pink,
          ),
          _StatItem(
            value: '${_calculateYouthPercentage()}%',
            label: 'Youth',
            icon: Icons.face,
            color: Colors.blue,
          ),
          _StatItem(
            value: '${_calculateActivePercentage()}%',
            label: 'Active',
            icon: Icons.check_circle,
            color: Colors.green,
          ),
        ],
      ),
    );
  }

  Widget _buildFarmersList() {
    if (_isLoading && _farmers.isEmpty) {
      return Center(child: CircularProgressIndicator());
    }

    if (_filteredFarmers.isEmpty) {
      return _buildEmptyState();
    }

    return RefreshIndicator(
      onRefresh: _loadFarmers,
      child: ListView.builder(
        controller: _scrollController,
        itemCount: _filteredFarmers.length + (_hasMore ? 1 : 0),
        itemBuilder: (context, index) {
          if (index == _filteredFarmers.length) {
            return _buildLoadMoreIndicator();
          }
          
          final farmer = _filteredFarmers[index];
          return _FarmerListItem(
            farmer: farmer,
            onTap: () => _showFarmerDetails(farmer),
            onEdit: () => _editFarmer(farmer),
            onDelete: () => _deleteFarmer(farmer),
          );
        },
      ),
    );
  }

  Widget _buildLoadMoreIndicator() {
    return Padding(
      padding: EdgeInsets.all(16),
      child: Center(
        child: _isLoading 
            ? CircularProgressIndicator()
            : Text('Load more farmers...'),
      ),
    );
  }

  Widget _buildEmptyState() {
    return Center(
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          Icon(Icons.people_outline, size: 80, color: Colors.grey[300]),
          SizedBox(height: 16),
          Text(
            'No farmers found',
            style: TextStyle(
              fontSize: 20,
              color: Colors.grey,
              fontWeight: FontWeight.bold,
            ),
          ),
          SizedBox(height: 8),
          Text(
            _searchController.text.isEmpty
                ? 'Add your first farmer to get started'
                : 'No farmers match your search criteria',
            style: TextStyle(color: Colors.grey),
            textAlign: TextAlign.center,
          ),
          SizedBox(height: 24),
          ElevatedButton.icon(
            onPressed: _showRegistrationForm,
            icon: Icon(Icons.add),
            label: Text('Register First Farmer'),
            style: ElevatedButton.styleFrom(
              backgroundColor: AppTheme.primaryGreen,
              foregroundColor: Colors.white,
              padding: EdgeInsets.symmetric(horizontal: 24, vertical: 12),
            ),
          ),
        ],
      ),
    );
  }

  void _showRegistrationForm() {
    showModalBottomSheet(
      context: context,
      isScrollControlled: true,
      backgroundColor: Colors.transparent,
      builder: (context) => Container(
        height: MediaQuery.of(context).size.height * 0.9,
        decoration: BoxDecoration(
          color: Colors.white,
          borderRadius: BorderRadius.only(
            topLeft: Radius.circular(24),
            topRight: Radius.circular(24),
          ),
        ),
        child: FarmerRegistrationForm(
          onSave: (farmer) {
            setState(() {
              _farmers.insert(0, farmer);
              _filterFarmers();
            });
            Navigator.pop(context);
            _showSuccessSnackbar('Farmer registered successfully!');
          },
        ),
      ),
    );
  }

  void _showFarmerDetails(FarmerProfile farmer) {
    Navigator.pushNamed(context, '/farmer-details', arguments: farmer);
  }

  void _editFarmer(FarmerProfile farmer) {
    // Implement edit functionality
  }

  void _deleteFarmer(FarmerProfile farmer) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: Text('Delete Farmer'),
        content: Text('Are you sure you want to delete ${farmer.name}?'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: Text('Cancel'),
          ),
          TextButton(
            onPressed: () {
              _performDelete(farmer);
              Navigator.pop(context);
            },
            child: Text('Delete', style: TextStyle(color: Colors.red)),
          ),
        ],
      ),
    );
  }

  void _performDelete(FarmerProfile farmer) {
    setState(() {
      _farmers.remove(farmer);
      _filterFarmers();
    });
    _showSuccessSnackbar('Farmer deleted successfully');
  }

  void _exportData() {
    // Implement export functionality
  }

  void _showFilters() {
    // Implement advanced filters
  }

  int _calculateWomenPercentage() {
    if (_farmers.isEmpty) return 0;
    final womenCount = _farmers.where((f) => f.isWomenLed).length;
    return ((womenCount / _farmers.length) * 100).round();
  }

  int _calculateYouthPercentage() {
    if (_farmers.isEmpty) return 0;
    final youthCount = _farmers.where((f) => f.isYouthLed).length;
    return ((youthCount / _farmers.length) * 100).round();
  }

  int _calculateActivePercentage() {
    if (_farmers.isEmpty) return 0;
    final activeCount = _farmers.where((f) => f.isActive).length;
    return ((activeCount / _farmers.length) * 100).round();
  }

  void _showSuccessSnackbar(String message) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: Colors.green,
        behavior: SnackBarBehavior.floating,
      ),
    );
  }

  void _showErrorSnackbar(String message) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: Colors.red,
        behavior: SnackBarBehavior.floating,
      ),
    );
  }

  @override
  bool get wantKeepAlive => true;
}

class _StatItem extends StatelessWidget {
  final String value;
  final String label;
  final IconData icon;
  final Color color;

  const _StatItem({
    required this.value,
    required this.label,
    required this.icon,
    required this.color,
  });

  @override
  Widget build(BuildContext context) {
    return Column(
      children: [
        Icon(icon, size: 20, color: color),
        SizedBox(height: 4),
        Text(
          value,
          style: TextStyle(
            fontSize: 16,
            fontWeight: FontWeight.bold,
            color: color,
          ),
        ),
        Text(
          label,
          style: TextStyle(
            fontSize: 12,
            color: Colors.grey,
          ),
        ),
      ],
    );
  }
}

class _FarmerListItem extends StatelessWidget {
  final FarmerProfile farmer;
  final VoidCallback onTap;
  final VoidCallback onEdit;
  final VoidCallback onDelete;

  const _FarmerListItem({
    required this.farmer,
    required this.onTap,
    required this.onEdit,
    required this.onDelete,
  });

  @override
  Widget build(BuildContext context) {
    return Card(
      margin: EdgeInsets.symmetric(horizontal: 16, vertical: 4),
      child: ListTile(
        leading: CircleAvatar(
          backgroundColor: _getStatusColor(farmer.status),
          child: Text(
            farmer.name.substring(0, 1).toUpperCase(),
            style: TextStyle(color: Colors.white),
          ),
        ),
        title: Text(
          farmer.name,
          style: TextStyle(fontWeight: FontWeight.bold),
        ),
        subtitle: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text('Phone: ${farmer.phone}'),
            Text('Village: ${farmer.village}'),
            Text('Farm Size: ${farmer.farmSize} hectares'),
            _buildStatusChips(farmer),
          ],
        ),
        trailing: PopupMenuButton<String>(
          icon: Icon(Icons.more_vert),
          itemBuilder: (context) => [
            PopupMenuItem(value: 'edit', child: Text('Edit')),
            PopupMenuItem(value: 'view', child: Text('View Details')),
            PopupMenuItem(value: 'delete', child: Text('Delete')),
          ],
          onSelected: (value) {
            switch (value) {
              case 'edit':
                onEdit();
                break;
              case 'view':
                onTap();
                break;
              case 'delete':
                onDelete();
                break;
            }
          },
        ),
        onTap: onTap,
      ),
    );
  }

  Widget _buildStatusChips(FarmerProfile farmer) {
    return Wrap(
      spacing: 4,
      children: [
        if (farmer.isWomenLed)
          Chip(
            label: Text('Women', style: TextStyle(fontSize: 10)),
            backgroundColor: Colors.pink[50],
            labelStyle: TextStyle(color: Colors.pink),
            materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
          ),
        if (farmer.isYouthLed)
          Chip(
            label: Text('Youth', style: TextStyle(fontSize: 10)),
            backgroundColor: Colors.blue[50],
            labelStyle: TextStyle(color: Colors.blue),
            materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
          ),
        Chip(
          label: Text(farmer.status.name.toUpperCase(), 
              style: TextStyle(fontSize: 10)),
          backgroundColor: _getStatusColor(farmer.status).withOpacity(0.2),
          labelStyle: TextStyle(color: _getStatusColor(farmer.status)),
          materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
        ),
      ],
    );
  }

  Color _getStatusColor(FarmerStatus status) {
    switch (status) {
      case FarmerStatus.active:
        return Colors.green;
      case FarmerStatus.inactive:
        return Colors.grey;
      case FarmerStatus.pending:
        return Colors.orange;
      case FarmerStatus.suspended:
        return Colors.red;
    }
  }
}
```

5. Enhanced Multi-Commodity Management

```dart
// lib/screens/farm_operations/multi_commodity_view.dart
import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import 'package:sena_farmerp/core/app_theme.dart';
import 'package:sena_farmerp/models/commodity_model.dart';
import 'package:sena_farmerp/services/api_service.dart';
import 'package:sena_farmerp/widgets/common/custom_app_bar.dart';
import 'package:sena_farmerp/widgets/common/dashboard_cards.dart';

class MultiCommodityView extends StatefulWidget {
  @override
  _MultiCommodityViewState createState() => _MultiCommodityViewState();
}

class _MultiCommodityViewState extends State<MultiCommodityView> 
    with AutomaticKeepAliveClientMixin {
  
  List<Commodity> _commodities = [];
  List<Commodity> _filteredCommodities = [];
  CommodityType _selectedType = CommodityType.all;
  String _searchQuery = '';
  bool _isLoading = false;

  @override
  void initState() {
    super.initState();
    _loadCommodities();
  }

  Future<void> _loadCommodities() async {
    setState(() {
      _isLoading = true;
    });

    try {
      final commodities = await Provider.of<ApiService>(context, listen: false)
          .getCommodities();
      
      setState(() {
        _commodities = commodities;
        _filteredCommodities = commodities;
        _isLoading = false;
      });
    } catch (e) {
      setState(() {
        _isLoading = false;
      });
      _showErrorSnackbar('Failed to load commodities: $e');
    }
  }

  void _filterCommodities() {
    setState(() {
      _filteredCommodities = _commodities.where((commodity) {
        final typeMatches = _selectedType == CommodityType.all || 
            commodity.type == _selectedType;
        final searchMatches = _searchQuery.isEmpty ||
            commodity.name.toLowerCase().contains(_searchQuery.toLowerCase()) ||
            commodity.variety.toLowerCase().contains(_searchQuery.toLowerCase());
        return typeMatches && searchMatches;
      }).toList();
    });
  }

  @override
  Widget build(BuildContext context) {
    super.build(context);
    return Scaffold(
      appBar: CustomAppBar(
        title: 'Multi-Commodity Management',
        subtitle: '87 Commodities • Real-time Monitoring',
        actions: [
          IconButton(
            icon: Icon(Icons.analytics),
            onPressed: _showAnalytics,
            tooltip: 'Commodity Analytics',
          ),
          IconButton(
            icon: Icon(Icons.add_chart),
            onPressed: _addCommodity,
            tooltip: 'Add New Commodity',
          ),
        ],
      ),
      body: Column(
        children: [
          // Enhanced Filter Section
          _buildFilterSection(),
          
          // Commodity Grid or List
          Expanded(
            child: _isLoading 
                ? _buildLoadingState()
                : _filteredCommodities.isEmpty
                    ? _buildEmptyState()
                    : _buildCommodityGrid(),
          ),
        ],
      ),
    );
  }

  Widget _buildFilterSection() {
    return Container(
      padding: EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: Colors.white,
        boxShadow: [
          BoxShadow(
            color: Colors.black12,
            blurRadius: 4,
            offset: Offset(0, 2),
          ),
        ],
      ),
      child: Column(
        children: [
          // Search Bar
          TextField(
            onChanged: (value) {
              _searchQuery = value;
              _filterCommodities();
            },
            decoration: InputDecoration(
              hintText: 'Search commodities...',
              prefixIcon: Icon(Icons.search),
              border: OutlineInputBorder(
                borderRadius: BorderRadius.circular(12),
              ),
            ),
          ),
          SizedBox(height: 12),
          
          // Filter Chips
          _buildFilterChips(),
          
          // Quick Stats
          _buildQuickStats(),
        ],
      ),
    );
  }

  Widget _buildFilterChips() {
    return SingleChildScrollView(
      scrollDirection: Axis.horizontal,
      child: Row(
        children: CommodityType.values.map((type) {
          return Padding(
            padding: EdgeInsets.only(right: 8),
            child: FilterChip(
              label: Text(
                _getTypeLabel(type),
                style: TextStyle(
                  color: _selectedType == type ? Colors.white : Colors.black,
                ),
              ),
              selected: _selectedType == type,
              onSelected: (selected) {
                setState(() {
                  _selectedType = selected ? type : CommodityType.all;
                  _filterCommodities();
                });
              },
              backgroundColor: Colors.grey[200],
              selectedColor: AppTheme.primaryGreen,
              checkmarkColor: Colors.white,
            ),
          );
        }).toList(),
      ),
    );
  }

  Widget _buildQuickStats() {
    final activeCommodities = _commodities.where((c) => c.isActive).length;
    final needsAttention = _commodities.where((c) => c.healthScore < 60).length;
    final highYield = _commodities.where((c) => c.expectedYield > 1000).length;

    return Container(
      margin: EdgeInsets.only(top: 12),
      padding: EdgeInsets.all(12),
      decoration: BoxDecoration(
        color: AppTheme.backgroundWhite,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: Colors.grey[300]!),
      ),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceAround,
        children: [
          _QuickStatItem(
            value: activeCommodities.toString(),
            label: 'Active',
            color: Colors.green,
          ),
          _QuickStatItem(
            value: needsAttention.toString(),
            label: 'Needs Care',
            color: Colors.orange,
          ),
          _QuickStatItem(
            value: highYield.toString(),
            label: 'High Yield',
            color: Colors.blue,
          ),
          _QuickStatItem(
            value: '${_calculateAvgHealthScore()}%',
            label: 'Avg Health',
            color: AppTheme.primaryGreen,
          ),
        ],
      ),
    );
  }

  Widget _buildCommodityGrid() {
    return GridView.builder(
      padding: EdgeInsets.all(16),
      gridDelegate: SliverGridDelegateWithFixedCrossAxisCount(
        crossAxisCount: _getCrossAxisCount(context),
        crossAxisSpacing: 16,
        mainAxisSpacing: 16,
        childAspectRatio: 1.1,
      ),
      itemCount: _filteredCommodities.length,
      itemBuilder: (context, index) {
        return _CommodityCard(
          commodity: _filteredCommodities[index],
          onTap: () => _showCommodityDetails(_filteredCommodities[index]),
        );
      },
    );
  }

  Widget _buildLoadingState() {
    return Center(
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          CircularProgressIndicator(),
          SizedBox(height: 16),
          Text('Loading commodities...'),
        ],
      ),
    );
  }

  Widget _buildEmptyState() {
    return Center(
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          Icon(Icons.agriculture, size: 80, color: Colors.grey[300]),
          SizedBox(height: 16),
          Text(
            'No commodities found',
            style: TextStyle(
              fontSize: 18,
              color: Colors.grey,
              fontWeight: FontWeight.bold,
            ),
          ),
          SizedBox(height: 8),
          Text(
            _searchQuery.isEmpty
                ? 'Try changing your filters'
                : 'No commodities match your search',
            style: TextStyle(color: Colors.grey),
          ),
          SizedBox(height: 16),
          ElevatedButton(
            onPressed: _loadCommodities,
            child: Text('Refresh'),
          ),
        ],
      ),
    );
  }

  int _getCrossAxisCount(BuildContext context) {
    final width = MediaQuery.of(context).size.width;
    if (width > 1200) return 4;
    if (width > 800) return 3;
    if (width > 600) return 2;
    return 1;
  }

  int _calculateAvgHealthScore() {
    if (_commodities.isEmpty) return 0;
    final total = _commodities.map((c) => c.healthScore).reduce((a, b) => a + b);
    return (total / _commodities.length).round();
  }

  void _showCommodityDetails(Commodity commodity) {
    Navigator.pushNamed(context, '/commodity-details', arguments: commodity);
  }

  void _showAnalytics() {
    Navigator.pushNamed(context, '/commodity-analytics');
  }

  void _addCommodity() {
    // Implement add commodity functionality
  }

  String _getTypeLabel(CommodityType type) {
    switch (type) {
      case CommodityType.all:
        return 'All Commodities';
      case CommodityType.crop:
        return 'Crops';
      case CommodityType.livestock:
        return 'Livestock';
      case CommodityType.horticulture:
        return 'Horticulture';
      case CommodityType.apiculture:
        return 'Apiculture';
      case CommodityType.aquaculture:
        return 'Aquaculture';
    }
  }

  void _showErrorSnackbar(String message) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: Colors.red,
        behavior: SnackBarBehavior.floating,
      ),
    );
  }

  @override
  bool get wantKeepAlive => true;
}

class _QuickStatItem extends StatelessWidget {
  final String value;
  final String label;
  final Color color;

  const _QuickStatItem({
    required this.value,
    required this.label,
    required this.color,
  });

  @override
  Widget build(BuildContext context) {
    return Column(
      children: [
        Container(
          width: 6,
          height: 6,
          decoration: BoxDecoration(
            color: color,
            shape: BoxShape.circle,
          ),
        ),
        SizedBox(height: 4),
        Text(
          value,
          style: TextStyle(
            fontSize: 14,
            fontWeight: FontWeight.bold,
            color: color,
          ),
        ),
        Text(
          label,
          style: TextStyle(
            fontSize: 10,
            color: Colors.grey,
          ),
        ),
      ],
    );
  }
}

class _CommodityCard extends StatelessWidget {
  final Commodity commodity;
  final VoidCallback onTap;

  const _CommodityCard({
    required this.commodity,
    required this.onTap,
  });

  @override
  Widget build(BuildContext context) {
    return Card(
      elevation: 2,
      child: InkWell(
        onTap: onTap,
        borderRadius: BorderRadius.circular(12),
        child: Padding(
          padding: EdgeInsets.all(16),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              // Header with Icon and Status
              Row(
                children: [
                  Container(
                    padding: EdgeInsets.all(8),
                    decoration: BoxDecoration(
                      color: _getCommodityColor(commodity.type),
                      borderRadius: BorderRadius.circular(8),
                    ),
                    child: Icon(
                      _getCommodityIcon(commodity.type),
                      color: Colors.white,
                      size: 20,
                    ),
                  ),
                  Spacer(),
                  _buildStatusIndicator(),
                ],
              ),
              SizedBox(height: 12),
              
              // Commodity Name and Variety
              Text(
                commodity.name,
                style: TextStyle(
                  fontSize: 16,
                  fontWeight: FontWeight.bold,
                ),
                maxLines: 1,
                overflow: TextOverflow.ellipsis,
              ),
              Text(
                commodity.variety,
                style: TextStyle(
                  fontSize: 12,
                  color: Colors.grey,
                ),
                maxLines: 1,
                overflow: TextOverflow.ellipsis,
              ),
              SizedBox(height: 8),
              
              // Production Metrics
              _buildProductionMetrics(),
              Spacer(),
              
              // Progress and Health
              _buildProgressIndicator(),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildStatusIndicator() {
    Color color;
    String status;
    
    if (commodity.healthScore >= 80) {
      color = Colors.green;
      status = 'Excellent';
    } else if (commodity.healthScore >= 60) {
      color = Colors.orange;
      status = 'Good';
    } else {
      color = Colors.red;
      status = 'Needs Care';
    }

    return Row(
      mainAxisSize: MainAxisSize.min,
      children: [
        Container(
          width: 6,
          height: 6,
          decoration: BoxDecoration(
            color: color,
            shape: BoxShape.circle,
          ),
        ),
        SizedBox(width: 4),
        Text(
          status,
          style: TextStyle(
            fontSize: 10,
            color: color,
            fontWeight: FontWeight.bold,
          ),
        ),
      ],
    );
  }

  Widget _buildProductionMetrics() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        _MetricRow(
          icon: Icons.landscape,
          value: '${commodity.plantedArea} ha',
          label: 'Area',
        ),
        _MetricRow(
          icon: Icons.trending_up,
          value: '${commodity.expectedYield} kg/ha',
          label: 'Yield',
        ),
        _MetricRow(
          icon: Icons.water_drop,
          value: '${commodity.waterRequirement}L',
          label: 'Water',
        ),
      ],
    );
  }

  Widget _buildProgressIndicator() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
          'Growth Progress',
          style: TextStyle(fontSize: 10, color: Colors.grey),
        ),
        SizedBox(height: 4),
        LinearProgressIndicator(
          value: commodity.growthProgress / 100,
          backgroundColor: Colors.grey[200],
          color: _getCommodityColor(commodity.type),
          minHeight: 6,
          borderRadius: BorderRadius.circular(3),
        ),
        SizedBox(height: 4),
        Row(
          mainAxisAlignment: MainAxisAlignment.spaceBetween,
          children: [
            Text(
              '${commodity.growthProgress}%',
              style: TextStyle(fontSize: 10, fontWeight: FontWeight.bold),
            ),
            Text(
              _getGrowthStage(commodity.growthProgress),
              style: TextStyle(fontSize: 10, color: Colors.grey),
            ),
          ],
        ),
      ],
    );
  }

  Color _getCommodityColor(CommodityType type) {
    switch (type) {
      case CommodityType.crop:
        return Colors.brown;
      case CommodityType.livestock:
        return Colors.orange;
      case CommodityType.horticulture:
        return Colors.green;
      case CommodityType.apiculture:
        return Colors.yellow[700]!;
      case CommodityType.aquaculture:
        return Colors.blue;
      default:
        return AppTheme.primaryGreen;
    }
  }

  IconData _getCommodityIcon(CommodityType type) {
    switch (type) {
      case CommodityType.crop:
        return Icons.grass;
      case CommodityType.livestock:
        return Icons.agriculture;
      case CommodityType.horticulture:
        return Icons.spa;
      case CommodityType.apiculture:
        return Icons.emoji_nature;
      case CommodityType.aquaculture:
        return Icons.water;
      default:
        return Icons.agriculture;
    }
  }

  String _getGrowthStage(int progress) {
    if (progress < 25) return 'Planting';
    if (progress < 50) return 'Vegetative';
    if (progress < 75) return 'Flowering';
    if (progress < 100) return 'Fruiting';
    return 'Harvest Ready';
  }
}

class _MetricRow extends StatelessWidget {
  final IconData icon;
  final String value;
  final String label;

  const _MetricRow({
    required this.icon,
    required this.value,
    required this.label,
  });

  @override
  Widget build(BuildContext context) {
    return Row(
      children: [
        Icon(icon, size: 12, color: Colors.grey),
        SizedBox(width: 4),
        Text(
          value,
          style: TextStyle(fontSize: 10, fontWeight: FontWeight.bold),
        ),
        SizedBox(width: 4),
        Text(
          label,
          style: TextStyle(fontSize: 10, color: Colors.grey),
        ),
      ],
    );
  }
}
```

6. Enhanced Value Chain Orchestrator

```dart
// lib/screens/value_chain/value_chain_orchestrator.dart
import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import 'package:sena_farmerp/core/app_theme.dart';
import 'package:sena_farmerp/models/value_chain_model.dart';
import 'package:sena_farmerp/services/api_service.dart';
import 'package:sena_farmerp/widgets/common/custom_app_bar.dart';
import 'package:sena_farmerp/widgets/common/dashboard_cards.dart';

class ValueChainOrchestratorScreen extends StatefulWidget {
  @override
  _ValueChainOrchestratorScreenState createState() => 
      _ValueChainOrchestratorScreenState();
}

class _ValueChainOrchestratorScreenState 
    extends State<ValueChainOrchestratorScreen> with AutomaticKeepAliveClientMixin {
  
  List<ValueChainPathway> _pathways = [];
  String _selectedCommodity = 'coffee';
  bool _isLoading = false;

  @override
  void initState() {
    super.initState();
    _loadValueChains();
  }

  Future<void> _loadValueChains() async {
    setState(() {
      _isLoading = true;
    });

    try {
      final pathways = await Provider.of<ApiService>(context, listen: false)
          .getValueChains();
      
      setState(() {
        _pathways = pathways;
        _isLoading = false;
      });
    } catch (e) {
      setState(() {
        _isLoading = false;
      });
      _showErrorSnackbar('Failed to load value chains: $e');
    }
  }

  ValueChainPathway? get _selectedPathway {
    try {
      return _pathways.firstWhere(
        (pathway) => pathway.commodity == _selectedCommodity,
      );
    } catch (e) {
      return _pathways.isNotEmpty ? _pathways.first : null;
    }
  }

  @override
  Widget build(BuildContext context) {
    super.build(context);
    return Scaffold(
      appBar: CustomAppBar(
        title: 'Value Chain Orchestrator',
        subtitle: 'End-to-End Agricultural Value Chain Management',
        actions: [
          IconButton(
            icon: Icon(Icons.link),
            onPressed: _showBlockchainExplorer,
            tooltip: 'Blockchain Explorer',
          ),
          IconButton(
            icon: Icon(Icons.auto_awesome),
            onPressed: _runAIOptimization,
            tooltip: 'AI Optimization',
          ),
        ],
      ),
      body: _isLoading
          ? _buildLoadingState()
          : _selectedPathway == null
              ? _buildEmptyState()
              : Column(
                  children: [
                    // Commodity Selector and Overview
                    _buildCommodityHeader(),
                    
                    // Value Chain Visualization
                    Expanded(
                      child: _buildValueChainVisualization(),
                    ),
                    
                    // Optimization Panel
                    _buildOptimizationPanel(),
                  ],
                ),
    );
  }

  Widget _buildCommodityHeader() {
    return Container(
      padding: EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: Colors.white,
        boxShadow: [
          BoxShadow(
            color: Colors.black12,
            blurRadius: 4,
            offset: Offset(0, 2),
          ),
        ],
      ),
      child: Column(
        children: [
          Row(
            children: [
              Expanded(
                child: _buildCommoditySelector(),
              ),
              SizedBox(width: 16),
              _buildValueChainMetrics(),
            ],
          ),
          SizedBox(height: 12),
          _buildPathwayOverview(),
        ],
      ),
    );
  }

  Widget _buildCommoditySelector() {
    return DropdownButtonFormField<String>(
      value: _selectedCommodity,
      decoration: InputDecoration(
        labelText: 'Select Commodity',
        border: OutlineInputBorder(),
        contentPadding: EdgeInsets.symmetric(horizontal: 12, vertical: 8),
      ),
      items: _pathways.map((pathway) {
        return DropdownMenuItem(
          value: pathway.commodity,
          child: Row(
            children: [
              Icon(_getCommodityIcon(pathway.commodity), size: 20),
              SizedBox(width: 8),
              Text(
                pathway.commodity.toUpperCase(),
                style: TextStyle(fontWeight: FontWeight.bold),
              ),
            ],
          ),
        );
      }).toList(),
      onChanged: (value) {
        setState(() {
          _selectedCommodity = value!;
        });
      },
    );
  }

  Widget _buildValueChainMetrics() {
    return Container(
      padding: EdgeInsets.all(12),
      decoration: BoxDecoration(
        color: AppTheme.primaryGreen.withOpacity(0.1),
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: AppTheme.primaryGreen.withOpacity(0.3)),
      ),
      child: Column(
        children: [
          Text(
            'Efficiency',
            style: TextStyle(fontSize: 12, color: Colors.grey),
          ),
          Text(
            '${_selectedPathway!.efficiency}%',
            style: TextStyle(
              fontSize: 18,
              fontWeight: FontWeight.bold,
              color: AppTheme.primaryGreen,
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildPathwayOverview() {
    return Row(
      children: [
        _OverviewMetric(
          value: _selectedPathway!.stages.length.toString(),
          label: 'Stages',
          icon: Icons.account_tree,
        ),
        _OverviewMetric(
          value: _selectedPathway!.totalParticipants.toString(),
          label: 'Participants',
          icon: Icons.people,
        ),
        _OverviewMetric(
          value: '\$${_selectedPathway!.estimatedValue}',
          label: 'Value',
          icon: Icons.attach_money,
        ),
        _OverviewMetric(
          value: '${_selectedPathway!.sustainabilityScore}%',
          label: 'Sustainability',
          icon: Icons.eco,
        ),
      ],
    );
  }

  Widget _buildValueChainVisualization() {
    return SingleChildScrollView(
      padding: EdgeInsets.all(16),
      child: Column(
        children: [
          // Value Chain Title
          Text(
            '${_selectedCommodity.toUpperCase()} VALUE CHAIN',
            style: TextStyle(
              fontSize: 24,
              fontWeight: FontWeight.bold,
              color: AppTheme.primaryGreen,
            ),
          ),
          SizedBox(height: 16),
          
          // Value Chain Stages
          ..._selectedPathway!.stages.asMap().entries.map((entry) {
            final index = entry.key;
            final stage = entry.value;
            return _ValueChainStageCard(
              stage: stage,
              stageNumber: index + 1,
              isLast: index == _selectedPathway!.stages.length - 1,
              totalStages: _selectedPathway!.stages.length,
            );
          }),
        ],
      ),
    );
  }

  Widget _buildOptimizationPanel() {
    return Container(
      padding: EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: Colors.grey[50],
        border: Border(top: BorderSide(color: Colors.grey[300]!)),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              Icon(Icons.auto_awesome, color: AppTheme.primaryOrange),
              SizedBox(width: 8),
              Text(
                'AI Optimization Recommendations',
                style: TextStyle(
                  fontSize: 16,
                  fontWeight: FontWeight.bold,
                ),
              ),
            ],
          ),
          SizedBox(height: 12),
          _buildOptimizationSuggestions(),
          SizedBox(height: 16),
          ElevatedButton.icon(
            onPressed: _runOptimization,
            icon: Icon(Icons.auto_awesome),
            label: Text('Run Advanced AI Optimization'),
            style: ElevatedButton.styleFrom(
              backgroundColor: AppTheme.primaryGreen,
              foregroundColor: Colors.white,
              minimumSize: Size(double.infinity, 50),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildOptimizationSuggestions() {
    return Column(
      children: [
        _OptimizationSuggestion(
          title: 'Reduce post-harvest losses by 15%',
          impact: '15% cost reduction',
          effort: 'Medium',
          savings: '\$2.5M annually',
          priority: 'High',
        ),
        _OptimizationSuggestion(
          title: 'Optimize input distribution network',
          impact: '20% efficiency gain',
          effort: 'Low',
          savings: '\$1.8M annually',
          priority: 'Medium',
        ),
        _OptimizationSuggestion(
          title: 'Implement AI-powered quality grading',
          impact: '25% price premium',
          effort: 'High',
          savings: '\$4.2M annually',
          priority: 'High',
        ),
      ],
    );
  }

  Widget _buildLoadingState() {
    return Center(
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          CircularProgressIndicator(),
          SizedBox(height: 16),
          Text('Loading value chains...'),
        ],
      ),
    );
  }

  Widget _buildEmptyState() {
    return Center(
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          Icon(Icons.account_tree, size: 80, color: Colors.grey[300]),
          SizedBox(height: 16),
          Text(
            'No value chains configured',
            style: TextStyle(
              fontSize: 18,
              color: Colors.grey,
              fontWeight: FontWeight.bold,
            ),
          ),
          SizedBox(height: 8),
          Text(
            'Configure value chains for your commodities',
            style: TextStyle(color: Colors.grey),
          ),
          SizedBox(height: 24),
          ElevatedButton(
            onPressed: _loadValueChains,
            child: Text('Retry'),
          ),
        ],
      ),
    );
  }

  IconData _getCommodityIcon(String commodity) {
    switch (commodity) {
      case 'coffee':
        return Icons.coffee;
      case 'tea':
        return Icons.emoji_food_beverage;
      case 'maize':
        return Icons.grass;
      case 'wheat':
        return Icons.grain;
      case 'livestock':
        return Icons.agriculture;
      default:
        return Icons.agriculture;
    }
  }

  void _showBlockchainExplorer() {
    Navigator.pushNamed(context, '/blockchain-explorer');
  }

  void _runAIOptimization() {
    // Implement AI optimization
  }

  void _runOptimization() {
    // Run optimization logic
  }

  void _showErrorSnackbar(String message) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: Colors.red,
        behavior: SnackBarBehavior.floating,
      ),
    );
  }

  @override
  bool get wantKeepAlive => true;
}

class _OverviewMetric extends StatelessWidget {
  final String value;
  final String label;
