1. Enhanced Main Application Entry Point

```dart
// lib/main.dart
import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import 'package:sena_farmerp/core/app_theme.dart';
import 'package:sena_farmerp/core/router.dart';
import 'package:sena_farmerp/core/app_config.dart';
import 'package:sena_farmerp/services/api_service.dart';
import 'package:sena_farmerp/services/auth_service.dart';
import 'package:sena_farmerp/services/blockchain_service.dart';
import 'package:sena_farmerp/services/analytics_service.dart';
import 'package:sena_farmerp/services/financial_service.dart';
import 'package:sena_farmerp/services/weather_service.dart';
import 'package:sena_farmerp/services/ai_advisory_service.dart';

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  
  // Initialize global configuration
  await AppConfig.initialize();
  
  // Initialize all services
  await AuthService().initialize();
  await ApiService().initialize();
  await BlockchainService().initialize();
  await AnalyticsService().initialize();
  await FinancialService().initialize();
  await WeatherService().initialize();
  await AIAdvisoryService().initialize();
  
  runApp(SenaFarmERPv6());
}

class SenaFarmERPv6 extends StatelessWidget {
  final AppRouter _router = AppRouter();

  @override
  Widget build(BuildContext context) {
    return MultiProvider(
      providers: [
        ChangeNotifierProvider(create: (_) => AuthService()),
        ChangeNotifierProvider(create: (_) => ApiService()),
        ChangeNotifierProvider(create: (_) => BlockchainService()),
        ChangeNotifierProvider(create: (_) => AnalyticsService()),
        ChangeNotifierProvider(create: (_) => FinancialService()),
        ChangeNotifierProvider(create: (_) => WeatherService()),
        ChangeNotifierProvider(create: (_) => AIAdvisoryService()),
      ],
      child: MaterialApp(
        title: 'Sena FarmERP v6.0 - World Flagship Agricultural OS',
        theme: AppTheme.lightTheme,
        darkTheme: AppTheme.darkTheme,
        themeMode: ThemeMode.light,
        initialRoute: '/splash',
        onGenerateRoute: _router.generateRoute,
        debugShowCheckedModeBanner: false,
        supportedLocales: const [
          Locale('en', 'US'),
          Locale('am', 'ET'),
          Locale('om', 'ET'),
          Locale('sw', 'KE'),
          Locale('fr', 'FR'),
        ],
        localizationsDelegates: const [
          // Add localization delegates
        ],
      ),
    );
  }
}
```

