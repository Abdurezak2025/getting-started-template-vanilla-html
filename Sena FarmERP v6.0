9. Enhanced Models

```dart
// lib/models/farmer_model.dart
class FarmerProfile {
  final String id;
  final String name;
  final String phone;
  final String email;
  final DateTime dateOfBirth;
  final Gender gender;
  final String village;
  final String district;
  final String region;
  final double farmSize;
  final double latitude;
  final double longitude;
  final FarmerStatus status;
  final DateTime registrationDate;
  final bool isWomenLed;
  final bool isYouthLed;
  final double annualIncome;
  final List<String> commodities;
  final List<FarmAsset> assets;
  final FinancialProfile financialProfile;
  final SocialInclusionProfile socialInclusion;
  final DigitalLiteracy digitalLiteracy;
  final bool isSynced;
  final DateTime lastUpdated;

  FarmerProfile({
    required this.id,
    required this.name,
    required this.phone,
    required this.email,
    required this.dateOfBirth,
    required this.gender,
    required this.village,
    required this.district,
    required this.region,
    required this.farmSize,
    required this.latitude,
    required this.longitude,
    this.status = FarmerStatus.active,
    required this.registrationDate,
    this.isWomenLed = false,
    this.isYouthLed = false,
    required this.annualIncome,
    required this.commodities,
    required this.assets,
    required this.financialProfile,
    required this.socialInclusion,
    required this.digitalLiteracy,
    this.isSynced = false,
    required this.lastUpdated,
  });

  factory FarmerProfile.fromJson(Map<String, dynamic> json) {
    return FarmerProfile(
      id: json['id'],
      name: json['name'],
      phone: json['phone'],
      email: json['email'],
      dateOfBirth: DateTime.parse(json['dateOfBirth']),
      gender: Gender.values.firstWhere((e) => e.name == json['gender']),
      village: json['village'],
      district: json['district'],
      region: json['region'],
      farmSize: json['farmSize'],
      latitude: json['latitude'],
      longitude: json['longitude'],
      status: FarmerStatus.values.firstWhere((e) => e.name == json['status']),
      registrationDate: DateTime.parse(json['registrationDate']),
      isWomenLed: json['isWomenLed'],
      isYouthLed: json['isYouthLed'],
      annualIncome: json['annualIncome'],
      commodities: List<String>.from(json['commodities']),
      assets: List<FarmAsset>.from(json['assets'].map((x) => FarmAsset.fromJson(x))),
      financialProfile: FinancialProfile.fromJson(json['financialProfile']),
      socialInclusion: SocialInclusionProfile.fromJson(json['socialInclusion']),
      digitalLiteracy: DigitalLiteracy.fromJson(json['digitalLiteracy']),
      isSynced: json['isSynced'],
      lastUpdated: DateTime.parse(json['lastUpdated']),
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'id': id,
      'name': name,
      'phone': phone,
      'email': email,
      'dateOfBirth': dateOfBirth.toIso8601String(),
      'gender': gender.name,
      'village': village,
      'district': district,
      'region': region,
      'farmSize': farmSize,
      'latitude': latitude,
      'longitude': longitude,
      'status': status.name,
      'registrationDate': registrationDate.toIso8601String(),
      'isWomenLed': isWomenLed,
      'isYouthLed': isYouthLed,
      'annualIncome': annualIncome,
      'commodities': commodities,
      'assets': assets.map((x) => x.toJson()).toList(),
      'financialProfile': financialProfile.toJson(),
      'socialInclusion': socialInclusion.toJson(),
      'digitalLiteracy': digitalLiteracy.toJson(),
      'isSynced': isSynced,
      'lastUpdated': lastUpdated.toIso8601String(),
    };
  }

  String get displayLocation => '$village, $district, $region';
  bool get isActive => status == FarmerStatus.active;
  bool get needsSupport => annualIncome < 1000; // Example threshold
  double get totalAssetValue => assets.fold(0, (sum, asset) => sum + asset.value);
}

enum Gender { male, female, other }
enum FarmerStatus { active, inactive, pending, suspended }

class FarmAsset {
  final String id;
  final AssetType type;
  final String description;
  final double value;
  final DateTime acquisitionDate;

  FarmAsset({
    required this.id,
    required this.type,
    required this.description,
    required this.value,
    required this.acquisitionDate,
  });

  factory FarmAsset.fromJson(Map<String, dynamic> json) {
    return FarmAsset(
      id: json['id'],
      type: AssetType.values.firstWhere((e) => e.name == json['type']),
      description: json['description'],
      value: json['value'],
      acquisitionDate: DateTime.parse(json['acquisitionDate']),
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'id': id,
      'type': type.name,
      'description': description,
      'value': value,
      'acquisitionDate': acquisitionDate.toIso8601String(),
    };
  }
}

enum AssetType { land, building, equipment, livestock, vehicle, other }

class FinancialProfile {
  final double creditScore;
  final double savings;
  final double loans;
  final List<InsurancePolicy> insurancePolicies;
  final List<Transaction> recentTransactions;

  FinancialProfile({
    required this.creditScore,
    required this.savings,
    required this.loans,
    required this.insurancePolicies,
    required this.recentTransactions,
  });

  factory FinancialProfile.fromJson(Map<String, dynamic> json) {
    return FinancialProfile(
      creditScore: json['creditScore'],
      savings: json['savings'],
      loans: json['loans'],
      insurancePolicies: List<InsurancePolicy>.from(
          json['insurancePolicies'].map((x) => InsurancePolicy.fromJson(x))),
      recentTransactions: List<Transaction>.from(
          json['recentTransactions'].map((x) => Transaction.fromJson(x))),
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'creditScore': creditScore,
      'savings': savings,
      'loans': loans,
      'insurancePolicies': insurancePolicies.map((x) => x.toJson()).toList(),
      'recentTransactions': recentTransactions.map((x) => x.toJson()).toList(),
    };
  }

  double get netWorth => savings - loans;
  bool get isCreditWorthy => creditScore >= 650;
}

class SocialInclusionProfile {
  final bool isWomenLed;
  final bool isYouthLed;
  final bool isDisabled;
  final bool isMinority;
  final List<TrainingCertificate> certificates;
  final List<SupportProgram> supportPrograms;

  SocialInclusionProfile({
    required this.isWomenLed,
    required this.isYouthLed,
    required this.isDisabled,
    required this.isMinority,
    required this.certificates,
    required this.supportPrograms,
  });

  factory SocialInclusionProfile.fromJson(Map<String, dynamic> json) {
    return SocialInclusionProfile(
      isWomenLed: json['isWomenLed'],
      isYouthLed: json['isYouthLed'],
      isDisabled: json['isDisabled'],
      isMinority: json['isMinority'],
      certificates: List<TrainingCertificate>.from(
          json['certificates'].map((x) => TrainingCertificate.fromJson(x))),
      supportPrograms: List<SupportProgram>.from(
          json['supportPrograms'].map((x) => SupportProgram.fromJson(x))),
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'isWomenLed': isWomenLed,
      'isYouthLed': isYouthLed,
      'isDisabled': isDisabled,
      'isMinority': isMinority,
      'certificates': certificates.map((x) => x.toJson()).toList(),
      'supportPrograms': supportPrograms.map((x) => x.toJson()).toList(),
    };
  }

  bool get isVulnerable => isWomenLed || isYouthLed || isDisabled || isMinority;
}

class DigitalLiteracy {
  final bool canUseSmartphone;
  final bool canUseApps;
  final bool hasInternetAccess;
  final String preferredLanguage;
  final List<String> usedApps;

  DigitalLiteracy({
    required this.canUseSmartphone,
    required this.canUseApps,
    required this.hasInternetAccess,
    required this.preferredLanguage,
    required this.usedApps,
  });

  factory DigitalLiteracy.fromJson(Map<String, dynamic> json) {
    return DigitalLiteracy(
      canUseSmartphone: json['canUseSmartphone'],
      canUseApps: json['canUseApps'],
      hasInternetAccess: json['hasInternetAccess'],
      preferredLanguage: json['preferredLanguage'],
      usedApps: List<String>.from(json['usedApps']),
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'canUseSmartphone': canUseSmartphone,
      'canUseApps': canUseApps,
      'hasInternetAccess': hasInternetAccess,
      'preferredLanguage': preferredLanguage,
      'usedApps': usedApps,
    };
  }

  bool get isDigitallyLiterate => canUseSmartphone && canUseApps;
}
