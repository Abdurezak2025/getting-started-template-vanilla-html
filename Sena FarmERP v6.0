    required this.icon,
  });

  @override
  Widget build(BuildContext context) {
    return Expanded(
      child: Column(
        children: [
          Icon(icon, size: 20, color: AppTheme.primaryGreen),
          SizedBox(height: 4),
          Text(
            value,
            style: TextStyle(
              fontSize: 14,
              fontWeight: FontWeight.bold,
            ),
          ),
          Text(
            label,
            style: TextStyle(
              fontSize: 10,
              color: Colors.grey,
            ),
          ),
        ],
      ),
    );
  }
}

class _ValueChainStageCard extends StatelessWidget {
  final ValueChainStage stage;
  final int stageNumber;
  final bool isLast;
  final int totalStages;

  const _ValueChainStageCard({
    required this.stage,
    required this.stageNumber,
    required this.isLast,
    required this.totalStages,
  });

  @override
  Widget build(BuildContext context) {
    return Card(
      margin: EdgeInsets.only(bottom: 16),
      child: Padding(
        padding: EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            // Stage Header
            Row(
              children: [
                // Stage Number with Connection Line
                Stack(
                  children: [
                    Container(
                      width: 40,
                      height: 40,
                      decoration: BoxDecoration(
                        color: AppTheme.primaryGreen,
                        shape: BoxShape.circle,
                      ),
                      child: Center(
                        child: Text(
                          stageNumber.toString(),
                          style: TextStyle(
                            color: Colors.white,
                            fontWeight: FontWeight.bold,
                          ),
                        ),
                      ),
                    ),
                    if (!isLast)
                      Positioned(
                        bottom: -20,
                        left: 20,
                        child: Container(
                          width: 2,
                          height: 20,
                          color: AppTheme.primaryGreen.withOpacity(0.5),
                        ),
                      ),
                  ],
                ),
                SizedBox(width: 12),
                Expanded(
                  child: Text(
                    stage.name,
                    style: TextStyle(
                      fontSize: 18,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                ),
                Icon(Icons.more_vert, color: Colors.grey),
              ],
            ),
            SizedBox(height: 12),
            
            // Stage Description
            Text(
              stage.description,
              style: TextStyle(color: Colors.grey[600]),
            ),
            SizedBox(height: 12),
            
            // Actors and Digital Tools
            Row(
              children: [
                Expanded(
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Text(
                        'Actors:',
                        style: TextStyle(
                          fontSize: 12,
                          fontWeight: FontWeight.bold,
                          color: Colors.grey,
                        ),
                      ),
                      SizedBox(height: 4),
                      Wrap(
                        spacing: 4,
                        children: stage.actors.map((actor) {
                          return Chip(
                            label: Text(actor),
                            backgroundColor: Colors.blue[50],
                            labelStyle: TextStyle(
                              fontSize: 10,
                              color: Colors.blue[700],
                            ),
                            materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                          );
                        }).toList(),
                      ),
                    ],
                  ),
                ),
                SizedBox(width: 16),
                Expanded(
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Text(
                        'Digital Tools:',
                        style: TextStyle(
                          fontSize: 12,
                          fontWeight: FontWeight.bold,
                          color: Colors.grey,
                        ),
                      ),
                      SizedBox(height: 4),
                      Wrap(
                        spacing: 4,
                        children: stage.digitalTools.map((tool) {
                          return Chip(
                            label: Text(tool),
                            backgroundColor: AppTheme.lightGreen.withOpacity(0.2),
                            labelStyle: TextStyle(
                              fontSize: 10,
                              color: AppTheme.primaryGreen,
                            ),
                            materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                          );
                        }).toList(),
                      ),
                    ],
                  ),
                ),
              ],
            ),
            SizedBox(height: 12),
            
            // Performance Metrics
            _buildPerformanceMetrics(),
          ],
        ),
      ),
    );
  }

  Widget _buildPerformanceMetrics() {
    return Container(
      padding: EdgeInsets.all(12),
      decoration: BoxDecoration(
        color: Colors.grey[50],
        borderRadius: BorderRadius.circular(8),
      ),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceAround,
        children: [
          _StageMetric(
            value: '${stage.efficiency}%',
            label: 'Efficiency',
            color: Colors.green,
          ),
          _StageMetric(
            value: '${stage.quality}%',
            label: 'Quality',
            color: Colors.blue,
          ),
          _StageMetric(
            value: '${stage.timeliness}%',
            label: 'Timeliness',
            color: Colors.orange,
          ),
          _StageMetric(
            value: '${stage.costEffectiveness}%',
            label: 'Cost Effective',
            color: Colors.purple,
          ),
        ],
      ),
    );
  }
}

class _StageMetric extends StatelessWidget {
  final String value;
  final String label;
  final Color color;

  const _StageMetric({
    required this.value,
    required this.label,
    required this.color,
  });

  @override
  Widget build(BuildContext context) {
    return Column(
      children: [
        Container(
          width: 6,
          height: 6,
          decoration: BoxDecoration(
            color: color,
            shape: BoxShape.circle,
          ),
        ),
        SizedBox(height: 4),
        Text(
          value,
          style: TextStyle(
            fontSize: 14,
            fontWeight: FontWeight.bold,
            color: color,
          ),
        ),
        Text(
          label,
          style: TextStyle(
            fontSize: 10,
            color: Colors.grey,
          ),
        ),
      ],
    );
  }
}

class _OptimizationSuggestion extends StatelessWidget {
  final String title;
  final String impact;
  final String effort;
  final String savings;
  final String priority;

  const _OptimizationSuggestion({
    required this.title,
    required this.impact,
    required this.effort,
    required this.savings,
    required this.priority,
  });

  @override
  Widget build(BuildContext context) {
    Color priorityColor;
    switch (priority.toLowerCase()) {
      case 'high':
        priorityColor = Colors.red;
        break;
      case 'medium':
        priorityColor = Colors.orange;
        break;
      case 'low':
        priorityColor = Colors.green;
        break;
      default:
        priorityColor = Colors.grey;
    }

    return Card(
      margin: EdgeInsets.only(bottom: 8),
      child: ListTile(
        leading: Container(
          width: 40,
          height: 40,
          decoration: BoxDecoration(
            color: priorityColor.withOpacity(0.2),
            shape: BoxShape.circle,
          ),
          child: Icon(
            Icons.lightbulb,
            color: priorityColor,
          ),
        ),
        title: Text(title),
        subtitle: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text('Impact: $impact • Effort: $effort'),
            Text('Savings: $savings'),
          ],
        ),
        trailing: Chip(
          label: Text(
            priority.toUpperCase(),
            style: TextStyle(
              fontSize: 10,
              color: Colors.white,
              fontWeight: FontWeight.bold,
            ),
          ),
          backgroundColor: priorityColor,
        ),
        onTap: () {
          // Show detailed suggestion
        },
      ),
    );
  }
}
