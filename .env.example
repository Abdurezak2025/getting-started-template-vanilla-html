# Sena FarmERP v7.0 - Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit actual .env file to git - this is for reference only

# Application Settings
APP_NAME=Sena FarmERP v7.0
APP_VERSION=7.0.0
APP_ENV=production
APP_DEBUG=false

# Domain Configuration
APP_URL=https://yourdomain.com
APP_DOMAIN=yourdomain.com
APP_PORT=3000

# API Configuration
API_BASE_URL=https://api.yourdomain.com
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3

# Weather API (Open-Meteo - Free)
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
WEATHER_LATITUDE=8.5
WEATHER_LONGITUDE=38.5

# Security
JWT_SECRET=your-secret-key-here
SESSION_SECRET=your-session-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# Database (if using backend)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=senafarm_db
DB_USER=senafarm_user
DB_PASSWORD=your-secure-password

# Email Service (Optional)
MAIL_FROM=noreply@yourdomain.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Storage (Optional)
STORAGE_PROVIDER=aws
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_BUCKET=sena-farmerp-bucket
AWS_REGION=us-east-1

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Cache
CACHE_TTL=3600
CACHE_DRIVER=memory

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=UA-XXXXXXXX-X
MIXPANEL_TOKEN=your-token

# Feature Flags
FEATURE_AI_DIAGNOSTICS=true
FEATURE_GIS_MAPPING=true
FEATURE_OFFLINE_MODE=true
FEATURE_MULTI_LANGUAGE=true

# PWA Configuration
PWA_ENABLED=true
PWA_CACHE_VERSION=v1
SERVICE_WORKER_ENABLED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_CREDENTIALS=true

# Node Environment
NODE_ENV=production
